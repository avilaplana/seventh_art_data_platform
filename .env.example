# AWS / MinIO credentials (shared across Spark, Airflow, MinIO, Iceberg REST)
AWS_ACCESS_KEY_ID=admin
AWS_SECRET_ACCESS_KEY=password
AWS_REGION=eu-west-2

# MinIO
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Iceberg REST catalog (JDBC)
CATALOG_JDBC_USER=iceberg
CATALOG_JDBC_PASSWORD=iceberg

# Airflow
AIRFLOW_WEBSERVER_SECRET_KEY=change_me
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres/airflow

# Host machine projects directory (mounted into Airflow containers)
PROJECTS_DIR=/your/projects/path
